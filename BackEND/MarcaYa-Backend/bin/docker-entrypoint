#!/bin/bash -e

# Force IPv4 for PostgreSQL — Supabase resolves to IPv6 and Render can't reach it.
# Must be set before any Ruby process starts (libpq reads it during C extension init).
export PGPREFER_IP_MODE=4

# If running the rails server then create or migrate existing database
if [ "$1" = "./bin/rails" ] && [ "$2" = "server" ]; then
  ./bin/rails db:prepare
fi

exec "${@}"
